      "source": [
        "## 8. Train Rewrite Reward Model"
      ],
      "metadata": {
        "id": "yh6RUxSYmQUS"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from reward_model import RewardModelConfig, RewardModelTrainer\n",
        "\n",
        "rm_config = RewardModelConfig(\n",
        "    data_path=\"./rlhf_data/rlhf_dataset.json\",\n",
        "    output_dir=\"./reward_model\",\n",
        "    base_model=\"microsoft/deberta-v3-small\",\n",
        "    epochs=3,\n",
        "    batch_size=8,\n",
        "    learning_rate=2e-5,\n",
        ")\n",
        "trainer = RewardModelTrainer(rm_config)\n",
        "trainer.train()"
      ],
